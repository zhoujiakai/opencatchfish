<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ListActivity">


    <ImageView
        android:id="@+id/list_ivtopimg"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/list_img"/>

    <ImageView

        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:id="@+id/list_lineimg"
        app:layout_constraintTop_toBottomOf="@id/list_ivtopimg"
        android:background="@drawable/game_line"/>

    <ListView
        android:id="@+id/list_rank_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/list_bg"
        app:layout_constraintTop_toBottomOf="@id/list_lineimg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>




</androidx.constraintlayout.widget.ConstraintLayout>