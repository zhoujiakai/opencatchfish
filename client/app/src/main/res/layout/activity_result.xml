<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="center"
    android:background="@drawable/result_bg"
    android:orientation="vertical"
    tools:context=".ResultActivity">
    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="500dp"
        android:layout_marginTop="100dp"
        android:layout_gravity="center"
        android:background="@drawable/result_bg"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/result_topImg"
            android:layout_width="355dp"
            android:layout_height="121dp"
            android:layout_gravity="center"
            android:layout_marginBottom="40dp"
            android:textSize="45sp"
            tools:background="@drawable/resultwin" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="抓鱼数量"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#000000"/>

                <TextView
                    android:id="@+id/result_fishCount"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:text="20"
                    android:textAlignment="center"
                    android:textSize="20sp"
                    android:singleLine="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="horizontal"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="游戏得分"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#000000"/>

                <TextView
                    android:id="@+id/result_score"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:text="3000"
                    android:textSize="20sp"
                    android:textAlignment="center"
                    android:singleLine="true" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="horizontal"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="历史最高"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#000000"/>

                <TextView
                    android:id="@+id/result_maxScore"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:text="3500"
                    android:textSize="20sp"
                    android:textAlignment="center"
                    android:singleLine="true" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="horizontal"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="全球排名"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#000000"/>

                <TextView
                    android:id="@+id/result_rankNumber"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textSize="20sp"
                    android:textAlignment="center"
                    android:singleLine="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/result_worldRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="30dp"
                android:background="#556677"
                android:text="查看全球排名"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_marginTop="30dp">

                <TextView
                    android:id="@+id/result_startAgain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="40dp"
                    android:text="  重新挑战  "
                    android:textSize="20sp"
                    android:background="#009988"/>

                <TextView
                    android:id="@+id/result_quitGame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="  退出游戏  "
                    android:textSize="20sp"
                    android:background="#009988"/>
            </LinearLayout>
        </LinearLayout>




    </LinearLayout>

</LinearLayout>